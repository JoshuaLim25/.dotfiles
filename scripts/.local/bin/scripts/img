#!/usr/bin/env bash

set -euo pipefail

SCREENSHOT_DIR="${HOME}/Downloads/Pictures/Screenshots"
mkdir -p "$SCREENSHOT_DIR"

FORMAT=$(echo -e "png\njpeg" | wofi --dmenu -p "Select format:")
[ -z "$FORMAT" ] && exit 0

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
grim -t "$FORMAT" -g "$(slurp)" "${SCREENSHOT_DIR}/Screenshot_${TIMESTAMP}.${FORMAT}"

notify-send "Screenshot Saved at $SCREENSHOT_DIR"
